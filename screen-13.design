ZS {
  Rect.fg(#121212).ignoresSafeArea
  VS(sp:0) {
    HS(px:16, py:12) {
      T("Good evening").title2.bold.fg(.white)
      Spacer
      HS(sp:16) {
        Img(sys:"bell").f(20).fg(.white)
        Img(sys:"clock.arrow.circlepath").f(20).fg(.white)
        Img(sys:"gearshape").f(20).fg(.white)
      }
    }
    Scroll {
      VS(sp:24, al:.leading, px:16, pt:8, pb:120) {
        VS(sp:8) {
          HS(sp:8) {
            ZS(al:.leading) {
              Rect.fg(#282828).frame(h:48).r(4)
              HS(sp:0) {
                Rect.fg(#1DB954).frame(w:48,h:48).r(4)
                T("Liked Songs").caption.bold.fg(.white).lineLimit(1).px(10)
              }
            }.frame(maxW:.inf)
            ZS(al:.leading) {
              Rect.fg(#282828).frame(h:48).r(4)
              HS(sp:0) {
                Rect.fg(#4ECDC4).frame(w:48,h:48).r(4)
                T("Daily Mix 1").caption.bold.fg(.white).lineLimit(1).px(10)
              }
            }.frame(maxW:.inf)
          }
          HS(sp:8) {
            ZS(al:.leading) {
              Rect.fg(#282828).frame(h:48).r(4)
              HS(sp:0) {
                Rect.fg(#E5625E).frame(w:48,h:48).r(4)
                T("Discover Weekly").caption.bold.fg(.white).lineLimit(1).px(10)
              }
            }.frame(maxW:.inf)
            ZS(al:.leading) {
              Rect.fg(#282828).frame(h:48).r(4)
              HS(sp:0) {
                Rect.fg(#6C5CE7).frame(w:48,h:48).r(4)
                T("Release Radar").caption.bold.fg(.white).lineLimit(1).px(10)
              }
            }.frame(maxW:.inf)
          }
          HS(sp:8) {
