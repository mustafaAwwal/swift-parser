              Rect.fg(#282828).frame(h:48).r(4)
              HS(sp:0) {
                Rect.fg(#FF9500).frame(w:48,h:48).r(4)
                T("Chill Vibes").caption.bold.fg(.white).lineLimit(1).px(10)
              }
            }.frame(maxW:.inf)
            ZS(al:.leading) {
              Rect.fg(#282828).frame(h:48).r(4)
              HS(sp:0) {
                Rect.fg(#FFD700).frame(w:48,h:48).r(4)
                T("Road Trip").caption.bold.fg(.white).lineLimit(1).px(10)
              }
            }.frame(maxW:.inf)
          }
        }
        VS(sp:12, al:.leading) {
          T("Recently Played").headline.bold.fg(.white)
          Scroll(.horizontal) {
            HS(sp:12, al:.top) {
              VS(sp:8, al:.leading) {
                Rect.fg(#1DB954).frame(w:140,h:140).r(8)
                T("Today's Top Hits").subheadline.bold.fg(.white).lineLimit(1)
                T("The biggest songs right now").caption.fg(.white.opacity(0.5)).lineLimit(2)
              }.frame(w:140)
              VS(sp:8, al:.leading) {
                Rect.fg(#E5625E).frame(w:140,h:140).r(8)
                T("RapCaviar").subheadline.bold.fg(.white).lineLimit(1)
                T("New music from Drake, Kendrick").caption.fg(.white.opacity(0.5)).lineLimit(2)
              }.frame(w:140)
              VS(sp:8, al:.leading) {
                Rect.fg(#6C5CE7).frame(w:140,h:140).r(8)
                T("Lofi Beats").subheadline.bold.fg(.white).lineLimit(1)
                T("Beats to relax and study to").caption.fg(.white.opacity(0.5)).lineLimit(2)
              }.frame(w:140)
              VS(sp:8, al:.leading) {
                Rect.fg(#4ECDC4).frame(w:140,h:140).r(8)
                T("Indie Pop").subheadline.bold.fg(.white).lineLimit(1)
                T("The best new indie").caption.fg(.white.opacity(0.5)).lineLimit(2)
              }.frame(w:140)
            }
          }
        }
        VS(sp:12, al:.leading) {
          T("Made for You").headline.bold.fg(.white)
          Scroll(.horizontal) {
            HS(sp:12, al:.top) {
              VS(sp:8, al:.center) {
                Circle.fg(#282828).frame(w:140,h:140)
                T("Daily Mix 1").subheadline.bold.fg(.white).lineLimit(1)
                T("Drake, Travis Scott, Future").caption.fg(.white.opacity(0.5)).lineLimit(1)
              }.frame(w:140)
              VS(sp:8, al:.center) {
                Circle.fg(#282828).frame(w:140,h:140)
                T("Daily Mix 2").subheadline.bold.fg(.white).lineLimit(1)
                T("The Weeknd, Doja Cat").caption.fg(.white.opacity(0.5)).lineLimit(1)
              }.frame(w:140)
