                T("Bonobo, Tycho, Khruangbin").caption.fg(.white.opacity(0.5)).lineLimit(1)
              }.frame(w:140)
            }
          }
        }
        VS(sp:12, al:.leading) {
          T("Popular Albums").headline.bold.fg(.white)
          Scroll(.horizontal) {
            HS(sp:12, al:.top) {
              VS(sp:8, al:.leading) {
                Rect.fg(#333333).frame(w:140,h:140).r(8)
                T("Midnights").subheadline.bold.fg(.white).lineLimit(1)
                T("Taylor Swift").caption.fg(.white.opacity(0.5)).lineLimit(1)
              }.frame(w:140)
              VS(sp:8, al:.leading) {
                Rect.fg(#333333).frame(w:140,h:140).r(8)
                T("SOS").subheadline.bold.fg(.white).lineLimit(1)
                T("SZA").caption.fg(.white.opacity(0.5)).lineLimit(1)
              }.frame(w:140)
