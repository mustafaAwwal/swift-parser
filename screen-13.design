          }
        }
      }
    }
    ZS {
      Rect.fg(#1DB954).frame(h:56).r(8).px(8)
      HS(sp:12, px:20) {
        Rect.fg(#282828).frame(w:40,h:40).r(4)
        VS(sp:2, al:.leading) {
          T("Blinding Lights").caption.bold.fg(.white)
          T("The Weeknd").caption.fg(.white.opacity(0.7))
