VS(sp:24, p:24) {
  Spacer

  VS(sp:8) {
    T("Welcome Back").bold.font(.largeTitle)
    T("Sign in to continue").secondary
  }

  VS(sp:12) {
    TF("Email")
    TF.secure("Password")
  }

  B.cta("Sign In")
  B.text("Forgot Password?").fg(.blue)

  Spacer

  HS(sp:4) {
    T("Don't have an account?").secondary.caption
    B.link("Sign Up")
  }
}
